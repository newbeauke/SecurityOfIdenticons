<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Security of Identicons</title>

    <!-- Bootstrap & HTMX -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>

    <!-- CSS -->
    <style>
        .identicon-grid { display: grid; gap: 1px; background: #dee2e6; border: 4px solid #212529; }
        .cell { width: 40px; height: 40px; }
    </style>
</head>
<body class="bg-light">
    <div class="container py-5">
        <header class="mb-5 text-center">
            <h1 class="display-4 fw-bold">Security of Identicons</h1>
            <p class="text-muted">Proof of Concept Identicon Generator & Testbench</p>
        </header>

        <!-- Inputs -->
        <section class="card mb-4">
            <div class="card-body">
                <input name="input" id="userInput" type="text" placeholder="Enter identifier" value="Beau Janssen"
                       hx-get="@Url.Action("GenerateResult", "Identicon")"
                       hx-trigger="keyup changed delay:200ms"
                       hx-target="#resultContainer"
                       hx-include="#resSelect, #symToggle, #colorCountSelect, #satSlider, #lightSlider"
                       class="form-control mb-3">

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Grid Size</label>
                        <select name="resolution" id="resSelect"
                                hx-get="@Url.Action("GenerateResult", "Identicon")"
                                hx-trigger="change"
                                hx-target="#resultContainer"
                                hx-include="#userInput, #symToggle, #colorCountSelect, #satSlider, #lightSlider"
                                class="form-select">
                            <option value="5">5x5 Grid</option>
                            <option value="7">7x7 Grid</option>
                            <option value="9">9x9 Grid</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Color Count</label>
                        <select name="colorCount" id="colorCountSelect"
                                hx-get="@Url.Action("GenerateResult", "Identicon")"
                                hx-trigger="change"
                                hx-target="#resultContainer"
                                hx-include="#userInput, #resSelect, #symToggle, #satSlider, #lightSlider"
                                class="form-select">
                            <option value="0">No color</option>
                            <option value="1" selected>1 color</option>
                            <option value="2">2 colors</option>
                            <option value="3">3 colors</option>
                        </select>
                    </div>

                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check">
                            <input name="isSymmetric" id="symToggle" type="checkbox" checked
                                   hx-get="@Url.Action("GenerateResult", "Identicon")"
                                   hx-trigger="change"
                                   hx-target="#resultContainer"
                                   hx-include="#userInput, #resSelect, #colorCountSelect, #satSlider, #lightSlider"
                                   hx-vals='js:{"isSymmetric": document.getElementById("symToggle").checked}'
                                   class="form-check-input">
                            <label class="form-check-label fw-semibold" for="symToggle">Symmetric</label>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label for="satSlider" class="form-label small fw-semibold">Saturation: <span id="satValue">70</span>%</label>
                        <input type="range" name="saturation" id="satSlider" min="0" max="100" value="70"
                               hx-get="@Url.Action("GenerateResult", "Identicon")"
                               hx-trigger="input changed delay:100ms"
                               hx-target="#resultContainer"
                               hx-include="#userInput, #resSelect, #symToggle, #colorCountSelect, #lightSlider"
                               class="form-range"
                               oninput="document.getElementById('satValue').textContent = this.value">
                    </div>

                    <div class="col-md-6">
                        <label for="lightSlider" class="form-label small fw-semibold">Lightness: <span id="lightValue">50</span>%</label>
                        <input type="range" name="lightness" id="lightSlider" min="0" max="100" value="50"
                               hx-get="@Url.Action("GenerateResult", "Identicon")"
                               hx-trigger="input changed delay:100ms"
                               hx-target="#resultContainer"
                               hx-include="#userInput, #resSelect, #symToggle, #colorCountSelect, #satSlider"
                               class="form-range"
                               oninput="document.getElementById('lightValue').textContent = this.value">
                    </div>
                </div>

                <button hx-get="@Url.Action("GenerateResult", "Identicon")"
                        hx-target="#resultContainer"
                        hx-include="#userInput, #resSelect, #symToggle, #colorCountSelect, #satSlider, #lightSlider"
                        class="btn btn-primary w-100">
                    Refresh
                </button>
            </div>
        </section>

        <!-- Results -->
        <div id="resultContainer"
             hx-get="@Url.Action("GenerateResult", "Identicon")"
             hx-trigger="load"
             hx-include="#userInput, #resSelect, #symToggle, #colorCountSelect, #satSlider, #lightSlider">
            <div class="text-center text-muted py-5">Loading...</div>
        </div>
    </div>
</body>
</html>