<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Security of Identicons</title>

    <!-- Bootstrap & HTMX -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>

    <!-- CSS -->
    <style>
        .identicon-grid { display: grid; gap: 1px; background: #dee2e6; border: 4px solid #212529; }
        .cell { width: 40px; height: 40px; }
        /* Smooth fade in for new content */
        .htmx-added { animation: fadeIn 0.3s ease-in; }
        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body class="bg-light">
    <div class="container py-5">
        <header class="mb-5">
            <h1 class="display-4 fw-bold text-uppercase">Identicon Security Lab</h1>
            <p class="text-muted">HTMX + C# Minimal API Baseline</p>
        </header>

        <!-- Input Section: Every change triggers a GET to /api/generate -->
        <section class="card mb-4">
            <div class="card-body">
                <input name="input" id="userInput" type="text" placeholder="Enter identifier..." value="s1154103@ru.nl"
                       hx-get="@Url.Action("GenerateResult", "Identicon")"
                       hx-trigger="keyup changed delay:200ms"
                       hx-target="#resultContainer"
                       hx-include="#resSelect, #symToggle"
                       class="form-control mb-3">

                <div class="d-flex gap-3 align-items-center">
                    <select name="resolution" id="resSelect"
                            hx-get="@Url.Action("GenerateResult", "Identicon")"
                            hx-trigger="change"
                            hx-target="#resultContainer"
                            hx-include="#userInput, #symToggle"
                            class="form-select" style="width: auto;">
                        <option value="5">5x5 Grid</option>
                        <option value="7">7x7 Grid</option>
                        <option value="9">9x9 Grid</option>
                    </select>

                    <div class="form-check">
                        <input name="isSymmetric" id="symToggle" type="checkbox" checked value="true"
                               hx-get="@Url.Action("GenerateResult", "Identicon")"
                               hx-trigger="change"
                               hx-target="#resultContainer"
                               hx-include="#userInput, #resSelect"
                               class="form-check-input">
                        <label class="form-check-label fw-semibold" for="symToggle">Symmetric</label>
                    </div>

                    <button hx-get="@Url.Action("GenerateResult", "Identicon")"
                            hx-target="#resultContainer"
                            hx-include="#userInput, #resSelect, #symToggle"
                            class="btn btn-primary ms-auto">
                        Refresh
                    </button>
                </div>
            </div>
        </section>

        <!-- Result container: HTMX will swap the innerHTML of this div -->
        <div id="resultContainer"
             hx-get="@Url.Action("GenerateResult", "Identicon")"
             hx-trigger="load"
             hx-include="#userInput, #resSelect, #symToggle">
            <div class="text-center text-muted py-5">Initializing laboratory...</div>
        </div>
    </div>
</body>
</html>