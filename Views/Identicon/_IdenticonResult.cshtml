@model List<SecurityOfIdenticons.IdenticonResult>
@{
    var parameters = ViewBag.Parameters as SecurityOfIdenticons.IdenticonParameters;
    var firstResult = Model.FirstOrDefault();
}

<div class="card lab-card animate-fadeIn">
<div class="card-body p-4">
        @if (firstResult != null && !string.IsNullOrEmpty(firstResult.WarningMessage))
        {
            <div class="alert @(firstResult.WarningMessage.StartsWith("Warning") ? "alert-warning" : "alert-info") text-center mb-4 small fw-semibold">
                @firstResult.WarningMessage
            </div>
        }
    <div class="row mb-5">
        <!-- Identicons -->
        @foreach (var result in Model)
        {
            <div class="col-md-6 text-center mb-4 mb-md-0">
                <h6 class="fw-bold mb-3">@result.Identifier</h6>
                <div style="display: grid; grid-template-columns: repeat(@result.Resolution, 1fr); margin: 0 auto; width: fit-content;">
                    @foreach (var colorIndex in result.Grid)
                    {
                        string bgColor;
                        if (colorIndex == 0)
                        {
                            bgColor = "#dee2e6";
                        }
                        else if (result.Colors != null && result.Colors.Count > 0 && colorIndex <= result.Colors.Count)
                        {
                            bgColor = result.Colors[colorIndex - 1];
                        }
                        else
                        {
                            bgColor = "black";
                        }
                        <div style="width: 40px; height: 40px; background-color: @bgColor;"></div>
                    }
                </div>
                <div class="mt-2 small text-muted font-mono uppercase">Resolution: @(result.Resolution)x@(result.Resolution)</div>
                @if (result.Colors != null && result.Colors.Count > 0)
                {
                    <div class="mt-2 d-flex justify-content-center gap-2">
                        @for (int i = 0; i < result.Colors.Count; i++)
                        {
                            <div class="p-1 text-white" style="height: 30px; background-color: @result.Colors[i]; border-radius: 4px;">@result.Colors[i]</div>
                        }
                    </div>
                }
                
                <div class="mt-4 text-start font-mono small bg-light p-2 rounded" style="word-break: break-all;">
                    <div class="text-muted text-uppercase mb-1" style="font-size: 0.7rem;">SHA-256 Hash (Hex)</div>
                    <div class="mb-2">@result.HashHex</div>
                    <div class="text-muted text-uppercase mb-1" style="font-size: 0.7rem;">Hash (Binary)</div>
                    <div>@result.HashBinary</div>
                </div>
            </div>
        }
    </div>

    <!-- Comparison Metrics Placeholder -->
    @if (Model.Count >= 2)
    {
        <div class="row mb-5">
            <div class="col-12">
                <h5 class="fw-bold border-bottom pb-2 mb-3 tracking-tight">Comparison Metrics</h5>
                <div class="p-4 bg-light rounded text-center text-muted fst-italic">
                    Similarity, distance, and visual entropy comparisons will be added here.
                </div>
            </div>
        </div>
    }

    <!-- Shared Data -->
    @if (firstResult != null)
    {
        <div class="row">
            <div class="col-12">
                <h5 class="fw-bold border-bottom pb-2 mb-3 tracking-tight">Shared Generation Metrics</h5>
                <div class="row g-3 font-mono">
                    <div class="col-md-3 col-6">
                        <div class="text-muted small uppercase">Total Entropy</div>
                        <div class="fw-bold">~@firstResult.EntropyBits.ToString("F1") bits</div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="text-muted small uppercase">Search Space</div>
                        <div class="fw-bold">@(Math.Pow(2, firstResult.EntropyBits).ToString("N0"))</div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="text-muted small uppercase">Color Mode</div>
                        <div class="fw-bold">@(parameters.ColorCount == 0 ? "None" : parameters.ColorCount + " color" + (parameters.ColorCount > 1 ? "s" : ""))</div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="text-muted small uppercase">Grid Mode</div>
                        <div class="fw-bold">@(parameters.IsSymmetric ? "Symmetric" : "Asymmetric")</div>
                    </div>
                </div>

                <!-- Entropy breakdown -->
                <div class="mt-4 p-3 bg-light rounded">
                    <h6 class="fw-bold small mb-2">Entropy breakdown</h6>
                    <div class="small font-mono">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Pattern (@firstResult.Resolution×@firstResult.Resolution @(parameters.IsSymmetric ? "symmetric" : "asymmetric")):</span>
                            <span class="fw-bold">@firstResult.PatternEntropyBits bits</span>
                        </div>
                        @if (parameters.ColorCount > 0)
                        {
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">Palette (@firstResult.PaletteOptions options, @(parameters.MinHueDistance)° apart):</span>
                                <span class="fw-bold">+@firstResult.PaletteEntropyBits.ToString("F1") bits</span>
                            </div>
                        }
                        @if (parameters.ColorCount > 1)
                        {
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">Color assignment (~@(firstResult.PatternEntropyBits / 2.0) avg active cells x @parameters.ColorCount colors):</span>
                                @if (@parameters.ColorCount == 2)
                                {
                                    <span class="fw-bold">+@firstResult.ColorEntropyBits.ToString("F1") bits</span>
                                }
                                else
                                {
                                    <span class="fw-bold">+((@(firstResult.PatternEntropyBits / 2.0)) x log₂(@parameters.ColorCount)) bits</span>
                                }
                            </div>
                        }
                        <div class="border-top border-secondary mt-2 pt-2 d-flex justify-content-between">
                            <span class="fw-bold">Total:</span>
                            <span class="fw-bold">~@firstResult.EntropyBits.ToString("F1") bits</span>
                        </div>
                    </div>
                </div>

                <div class="mt-3 p-3 bg-light rounded small italic text-secondary">
                    A 1-bit change in the input hash shifts the @firstResult.Resolution-grid structure by approximately @((100.0 / firstResult.EntropyBits).ToString("F1"))%
                </div>
            </div>
        </div>
    }
</div>
</div>